# Root env for both server and Vite development

# Server
PORT=4200
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174
CACHE_TTL=300

# Database (brum_flow schema)
DATABASE_URL=postgresql://supabase_admin:YOUR_PASSWORD@192.168.0.74:5433/postgres

# Auth / access
SUPABASE_URL=http://192.168.0.74
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret
APP_SLUG=brum-flow
GOOGLE_WORKSPACE_DOMAIN=the-boundary.com
PUBLIC_BASE_URL=http://localhost:4200
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Local development shortcut
DEV_AUTH_BYPASS=true

# Client (Vite)
VITE_DEV_PORT=5174
VITE_BACKEND_PORT=4200
